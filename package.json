{
  "name": "fave-money-ts-appium-suite",
  "version": "1.0.0",
  "private": true,
  "author": {
    "name": "Parikshit Bhatt"
  },
  "description": "Black-box TypeScript automation suite for Fave Money with Homes & Groups features covered, runnable locally (Appium) or on BrowserStack App Automate",
  "scripts": {
    "test:local": "wdio run ./wdio.local.conf.ts",
    "test:browserstack": "wdio run ./wdio.browserstack.conf.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@wdio/browserstack-service": "^9.4.0",
    "@wdio/cli": "^9.4.0",
    "@wdio/local-runner": "^9.4.0",
    "@wdio/mocha-framework": "^9.4.0",
    "@wdio/spec-reporter": "^9.4.0",
    "appium": "^2.11.0",
    "appium-uiautomator2-driver": "^3.7.0",
    "browserstack-local": "^1.5.6",
    "typescript": "^5.5.0",
    "ts-node": "^10.9.2",
    "@types/node": "^20.14.0",
    "@wdio/types": "^9.4.0"
  }
}
