{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "@wdio/globals/types", "expect-webdriverio", "mocha"],
    "outDir": "./build"
  },
  "include": ["src/**/*.ts", "wdio.*.conf.ts"]
}
